# Server
BASE_URL=http://localhost:3000
PORT=3000
DB_PATH=./data/games.db

# AI Providers — add only the ones you want enabled.
# Models from unconfigured providers are automatically hidden in the UI.
# At least one must be set (or use Ollama locally).

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Ollama (local) — no key needed, defaults to http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# AI Behaviour
DEFAULT_MODEL=claude-haiku-4-5
MAX_TOKENS=2000
MAX_DESCRIPTION_LENGTH=500

# Rate Limiting
RATE_LIMIT_POINTS=5
RATE_LIMIT_DURATION=3600
